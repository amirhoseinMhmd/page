---
import { SITE, absoluteUrl, personId, websiteId } from '../data/site';

interface Props {
  title: string;
  description?: string;
  htmlClass?: string;
  canonicalPath?: string;
  pageType?: 'website' | 'article';
  image?: string;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = SITE.description,
  htmlClass = '',
  canonicalPath,
  pageType = 'website',
  image = SITE.defaultImage,
  noindex = false,
  publishedTime,
  modifiedTime,
} = Astro.props;

const canonicalUrl = absoluteUrl(canonicalPath ?? Astro.url.pathname);
const imageUrl = absoluteUrl(image);
const robotsContent = noindex ? 'noindex,follow' : 'index,follow';
const gaMeasurementId = import.meta.env.PROD ? 'G-BH7LEVWN7X' : null;
const baseStructuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': personId(),
      name: SITE.author.name,
      url: absoluteUrl('/'),
      image: imageUrl,
      email: `mailto:${SITE.author.email}`,
      jobTitle: SITE.author.jobTitle,
      affiliation: {
        '@type': 'Organization',
        name: SITE.author.affiliation,
        url: 'https://www.uu.nl/',
      },
      sameAs: SITE.author.sameAs,
    },
    {
      '@type': 'WebSite',
      '@id': websiteId(),
      url: absoluteUrl('/'),
      name: SITE.name,
      description: SITE.description,
      inLanguage: SITE.language,
      publisher: {
        '@id': personId(),
      },
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en" class={htmlClass}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robotsContent} />
  <meta name="author" content={SITE.author.name} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={pageType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:image" content={imageUrl} />
  <meta property="og:locale" content="en_US" />
  {pageType === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )}
  {pageType === 'article' && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime} />
  )}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />
  <link rel="icon" href="data:image/svg+xml,%3Csvg width='128' height='128' viewBox='0 0 128 128' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='128' height='128' fill='%23111'/%3E%3Ctext x='50%25' y='50%25' dominant-baseline='central' text-anchor='middle' font-family='Georgia,serif' font-size='54' fill='%23fff'%3EAM%3C/text%3E%3C/svg%3E" type="image/svg+xml" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Source+Sans+3:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  {gaMeasurementId && (
    <>
      <script
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
      ></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-BH7LEVWN7X');
      </script>
    </>
  )}
  <script
    type="application/ld+json"
    set:html={JSON.stringify(baseStructuredData)}
  ></script>
  <style is:global>
    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
    }
  </style>
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
