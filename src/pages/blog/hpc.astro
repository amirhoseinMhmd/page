---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blog';
import SlurmScriptBuilder from '../../components/SlurmScriptBuilder';
import SshCommandBuilder from '../../components/SshCommandBuilder';

const article = blogPosts.find((post) => post.slug === 'hpc');

if (!article) {
  throw new Error('Missing blog metadata for the HPC article.');
}

const articleUrl = `https://amirhosein.nl${article.href}`;
const updatedLabel = article.updatedOn
  ? new Date(`${article.updatedOn}T00:00:00`).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : null;
const articleStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: article.title,
  description: article.description,
  datePublished: article.publishedOn,
  dateModified: article.updatedOn ?? article.publishedOn,
  author: {
    '@type': 'Person',
    name: 'Amirhossein Mohammadi',
    url: 'https://amirhosein.nl/',
  },
  mainEntityOfPage: articleUrl,
  url: articleUrl,
  keywords: article.tags.join(', '),
};
---

<BaseLayout
  title={`${article.title} — Amirhossein Mohammadi`}
  description={article.description}
  htmlClass="scroll-smooth"
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(articleStructuredData)}
    ></script>
  </Fragment>
  <style is:global>
    :root {
      --ink: #111;
      --ink-mid: #444;
      --ink-light: #777;
      --ink-faint: #aaa;
      --bg: #fff;
      --bg-subtle: #f9f9f9;
      --rule: #e4e4e4;
      --accent: #2a5caa;
      --accent-light: #e8eef8;
      --green: #2e7d32;
      --green-light: #e8f4e8;
      --red: #c0392b;
      --red-light: #fff5f5;
      --orange: #e65100;
      --orange-light: #fff3e0;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-padding-top: 3.5rem; }

    body {
      font-family: 'Source Sans 3', sans-serif;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .reading-progress {
      position: fixed;
      top: 3rem;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, #2a5caa 0%, #5f87d3 100%);
      transform: scaleX(0);
      transform-origin: left center;
      z-index: 101;
      opacity: 0.95;
      pointer-events: none;
    }

    .nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--rule);
    }
    .nav-inner {
      max-width: 760px; margin: 0 auto; padding: 0 1.5rem;
      display: flex; align-items: center; justify-content: space-between;
      height: 3rem;
    }
    .nav-name {
      font-family: 'EB Garamond', serif;
      font-size: 1.05rem; font-weight: 500;
      color: var(--ink); text-decoration: none;
    }
    .nav-links { display: flex; gap: 0.1rem; }
    .nav-links a {
      font-size: 0.75rem; font-weight: 600; color: var(--ink-light);
      text-decoration: none; padding: 0.3rem 0.55rem; border-radius: 3px;
      letter-spacing: 0.05em; text-transform: uppercase;
      transition: color 0.15s, background 0.15s;
    }
    .nav-links a:hover { color: var(--ink); background: var(--bg-subtle); }
    .nav-links a.active { color: var(--accent); }
    .mobile-toggle {
      display: none; background: none; border: none;
      font-size: 1.1rem; color: var(--ink-light); cursor: pointer; padding: 0.4rem;
    }
    .mobile-nav { display: none; border-bottom: 1px solid var(--rule); padding: 0.5rem 1.5rem 0.75rem; }
    .mobile-nav.open { display: block; }
    .mobile-nav a {
      display: block; font-size: 0.85rem; font-weight: 600; color: var(--ink-light);
      text-decoration: none; padding: 0.4rem 0; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .mobile-nav a:hover { color: var(--ink); }
    @media (max-width: 640px) {
      .nav-links { display: none; }
      .mobile-toggle { display: block; }
    }

    .page { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }

    .article-header { padding: 3rem 0 2rem; border-bottom: 1px solid var(--rule); }
    .article-back {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.77rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--ink-faint); text-decoration: none;
      margin-bottom: 1.75rem; transition: color 0.15s;
    }
    .article-back:hover { color: var(--accent); }
    .article-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.1rem; }
    .article-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem; color: var(--ink-light);
      background: #f0f0f0; padding: 0.15rem 0.5rem; border-radius: 2px;
    }
    .article-tag.tut { background: var(--orange-light); color: var(--orange); }
    .article-tag.hl { background: var(--accent-light); color: var(--accent); }
    .article-header h1 {
      font-family: 'EB Garamond', serif;
      font-size: 2.05rem; font-weight: 500; line-height: 1.2;
      color: var(--ink); margin-bottom: 0.55rem;
    }
    .article-header .subtitle {
      font-family: 'EB Garamond', serif;
      font-size: 1.1rem; font-style: italic; color: var(--ink-light);
      margin-bottom: 0.9rem;
    }
    .article-meta {
      display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap;
      font-size: 0.82rem; color: var(--ink-faint); margin-bottom: 1.25rem;
    }
    .article-meta .date { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; }
    .article-meta .authors { font-family: 'EB Garamond', serif; font-size: 0.95rem; color: var(--ink-mid); font-style: italic; }
    .article-meta .sep { color: var(--rule); }

    .reader-start {
      padding: 1.65rem 0 0.4rem;
    }
    .reader-start-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .summary-panel {
      background: linear-gradient(180deg, #fbfcfe 0%, #f6f8fc 100%);
      border: 1px solid var(--rule);
      border-radius: 10px;
      padding: 1.1rem 1.15rem;
    }
    .summary-panel.alt {
      background: linear-gradient(180deg, #fdfcf8 0%, #faf7ef 100%);
    }
    .summary-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.55rem;
    }
    .summary-panel.alt .summary-eyebrow {
      color: var(--orange);
    }
    .summary-panel h2 {
      font-family: 'EB Garamond', serif;
      font-size: 1.35rem;
      font-weight: 600;
      line-height: 1.2;
      margin-bottom: 0.45rem;
      color: var(--ink);
    }
    .summary-panel p {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--ink-light);
      margin-bottom: 0.8rem;
    }
    .summary-list {
      padding-left: 1.1rem;
      display: grid;
      gap: 0.4rem;
      color: var(--ink-mid);
    }
    .summary-list li {
      font-family: 'EB Garamond', serif;
      font-size: 1rem;
      line-height: 1.6;
    }
    .jump-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 1rem 0 0;
    }
    .jump-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      border: 1px solid var(--rule);
      border-radius: 999px;
      background: #fff;
      padding: 0.48rem 0.8rem;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--ink-mid);
      text-decoration: none;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .jump-link:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: #fafcff;
    }
    @media (max-width: 640px) {
      .reader-start-grid {
        grid-template-columns: 1fr;
      }
    }

    .toc {
      background: var(--bg-subtle); border: 1px solid var(--rule);
      border-radius: 6px; padding: 1.1rem 1.3rem; margin: 2rem 0;
    }
    .toc-title {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.07em; color: var(--ink-faint); margin-bottom: 0.7rem;
    }
    .toc ol { padding-left: 1.3rem; margin: 0; }
    .toc li {
      font-family: 'EB Garamond', serif;
      font-size: 1rem; color: var(--ink-mid);
      margin-bottom: 0.25rem; line-height: 1.5;
    }
    .toc a { color: var(--ink-mid); text-decoration: none; transition: color 0.15s; }
    .toc a:hover { color: var(--accent); }
    .toc a.active { color: var(--accent); font-weight: 600; }

    .article-body { padding: 2.25rem 0; }
    .article-body p {
      font-family: 'EB Garamond', serif;
      font-size: 1.07rem; line-height: 1.87; color: var(--ink-mid);
      margin-bottom: 1.1rem;
    }
    .article-body p:last-child { margin-bottom: 0; }
    .article-body h2 {
      font-family: 'EB Garamond', serif;
      font-size: 1.5rem; font-weight: 500; color: var(--ink);
      margin: 2.75rem 0 0.9rem; padding-top: 0.5rem;
      border-top: 1px solid var(--rule);
    }
    .article-body h2:first-child { margin-top: 0; border-top: none; }
    .article-body h2 .step-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem; background: var(--accent); color: #fff;
      border-radius: 3px; padding: 0.15rem 0.45rem;
      margin-right: 0.6rem; vertical-align: middle; position: relative; top: -2px;
    }
    .article-body h3 {
      font-family: 'EB Garamond', serif;
      font-size: 1.2rem; font-weight: 600; color: var(--ink);
      margin: 1.75rem 0 0.55rem;
    }
    .article-body a {
      color: var(--ink); text-decoration: underline;
      text-underline-offset: 2px; text-decoration-color: var(--rule);
      transition: color 0.15s, text-decoration-color 0.15s;
    }
    .article-body a:hover { color: var(--accent); text-decoration-color: var(--accent); }
    .article-body strong { font-weight: 600; color: var(--ink); }
    .article-body em { font-style: italic; }

    code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85em;
      background: #f0f0f0; color: var(--ink-mid);
      padding: 0.1em 0.35em; border-radius: 3px;
    }

    .callout {
      border-radius: 0 6px 6px 0; padding: 1rem 1.25rem; margin: 1.5rem 0;
    }
    .callout.info { background: var(--accent-light); border-left: 3px solid var(--accent); }
    .callout.tip { background: var(--green-light); border-left: 3px solid var(--green); }
    .callout.warn { background: var(--orange-light); border-left: 3px solid var(--orange); }
    .callout.danger { background: var(--red-light); border-left: 3px solid var(--red); }
    .callout-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; margin-bottom: 0.4rem;
    }
    .callout.info .callout-label { color: var(--accent); }
    .callout.tip .callout-label { color: var(--green); }
    .callout.warn .callout-label { color: var(--orange); }
    .callout.danger .callout-label { color: var(--red); }
    .callout p { font-size: 1rem !important; margin-bottom: 0.4rem !important; color: var(--ink-mid); }
    .callout p:last-child { margin-bottom: 0 !important; }
    .callout ul {
      font-family: 'EB Garamond', serif; font-size: 1rem;
      color: var(--ink-mid); padding-left: 1.3rem; margin-top: 0.3rem;
    }
    .callout li { margin-bottom: 0.2rem; line-height: 1.65; }

    .steps { margin: 1.25rem 0; }
    .step-item {
      display: grid; grid-template-columns: 2rem 1fr;
      gap: 0 0.9rem; margin-bottom: 1.2rem; align-items: start;
    }
    .step-circle {
      width: 2rem; height: 2rem; border-radius: 50%;
      background: var(--accent); color: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem; font-weight: 500;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 0.1rem;
    }
    .step-title {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.9rem; font-weight: 600; color: var(--ink);
      margin-bottom: 0.2rem;
    }
    .step-desc {
      font-family: 'EB Garamond', serif;
      font-size: 1rem; color: var(--ink-mid); line-height: 1.65;
    }

    .code-block-wrap {
      margin: 1.25rem 0;
    }
    .code-block-toolbar {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 0.4rem;
    }
    .copy-code-button {
      border: 1px solid var(--rule);
      background: #fff;
      color: var(--ink-light);
      border-radius: 999px;
      padding: 0.38rem 0.75rem;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      cursor: pointer;
      transition: 0.15s ease;
    }
    .copy-code-button:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
    .copy-code-button.copied {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    .code-block {
      background: #1e1e2e; color: #cdd6f4;
      border-radius: 6px; padding: 1.1rem 1.2rem; margin: 0;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.82rem; line-height: 1.7;
      overflow-x: auto; white-space: pre;
    }
    .code-block .c-comment { color: #6c7086; }
    .code-block .c-key { color: #cba6f7; }
    .code-block .c-str { color: #a6e3a1; }
    .code-block .c-num { color: #fab387; }
    .code-block .c-fn { color: #89b4fa; }
    .code-block-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.07em; color: var(--ink-faint);
      margin-bottom: 0.35rem; margin-top: 1.25rem;
    }

    .compare-table {
      width: 100%; border-collapse: collapse;
      font-family: 'EB Garamond', serif; font-size: 0.97rem;
      margin: 1.4rem 0; border: 1px solid var(--rule); border-radius: 6px;
      overflow: hidden;
    }
    .compare-table th {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.07em; color: var(--ink-light);
      background: var(--bg-subtle); padding: 0.55rem 0.9rem;
      text-align: left; border-bottom: 1px solid var(--rule);
    }
    .compare-table td {
      padding: 0.6rem 0.9rem; color: var(--ink-mid);
      border-bottom: 1px solid #f0f0f0; vertical-align: top; line-height: 1.55;
    }
    .compare-table tr:nth-child(even) td { background: var(--bg-subtle); }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table .cmd-col {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem; color: var(--ink); white-space: nowrap;
      font-weight: 500; width: 42%;
    }
    .compare-table .desc-col {
      font-family: 'EB Garamond', serif; font-size: 0.97rem;
    }

    .insight {
      display: flex; gap: 1rem; align-items: flex-start;
      background: var(--bg-subtle); border: 1px solid var(--rule);
      border-radius: 8px; padding: 1rem 1.1rem; margin: 1.25rem 0;
    }
    .insight-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.05rem; }
    .insight-body { font-family: 'EB Garamond', serif; font-size: 1rem; color: var(--ink-mid); line-height: 1.7; }
    .insight-body strong { color: var(--ink); font-weight: 600; }

    .try-it {
      background: #1e1e2e; border-radius: 8px;
      padding: 1.3rem 1.5rem; margin: 1.3rem 0;
    }
    .try-it-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.07em; color: #6c7086; margin-bottom: 0.8rem;
    }
    .try-it-links { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .try-it-link {
      display: inline-flex; align-items: center; gap: 0.35rem;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.78rem; font-weight: 600; text-decoration: none;
      padding: 0.4rem 0.85rem; border-radius: 5px; transition: opacity 0.15s;
    }
    .try-it-link:hover { opacity: 0.85; }
    .try-it-link.gh { background: #313244; color: #cdd6f4; }
    .try-it-link.doc { background: #45475a; color: #cdd6f4; }

    .issue-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.9rem;
      margin: 1.35rem 0;
    }
    .issue-card {
      border: 1px solid var(--rule);
      border-radius: 8px;
      background: #fff;
      padding: 1rem 1rem 0.95rem;
    }
    .issue-card h3 {
      margin: 0 0 0.45rem;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.96rem;
      font-weight: 700;
      color: var(--ink);
    }
    .issue-card p {
      margin: 0;
      font-family: 'EB Garamond', serif;
      font-size: 1rem;
      line-height: 1.65;
      color: var(--ink-mid);
    }

    .next-steps {
      margin-top: 2rem;
      padding: 1.35rem 1.45rem;
      border: 1px solid var(--rule);
      border-radius: 10px;
      background: linear-gradient(180deg, #fcfcfd 0%, #f7f8fb 100%);
    }
    .next-steps-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }
    .next-steps h2 {
      margin: 0 0 0.35rem;
      font-family: 'EB Garamond', serif;
      font-size: 1.45rem;
      font-weight: 600;
      color: var(--ink);
    }
    .next-steps > p {
      margin: 0 0 1rem;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      color: var(--ink-light);
    }
    .next-steps-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .next-step-card {
      display: grid;
      gap: 0.3rem;
      border: 1px solid var(--rule);
      border-radius: 8px;
      background: #fff;
      padding: 0.95rem 1rem;
      text-decoration: none;
      color: inherit;
      transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .next-step-card:hover {
      transform: translateY(-1px);
      border-color: #c8d5ef;
      box-shadow: 0 12px 28px rgba(17, 17, 17, 0.05);
    }
    .next-step-card strong {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      color: var(--ink);
    }
    .next-step-card span {
      font-family: 'EB Garamond', serif;
      font-size: 0.98rem;
      line-height: 1.55;
      color: var(--ink-mid);
    }

    .island-card {
      background: linear-gradient(180deg, #fcfcfd 0%, #f7f8fb 100%);
      border: 1px solid var(--rule);
      border-radius: 10px;
      padding: 1.1rem 1.15rem;
      margin: 1.5rem 0;
      box-shadow: 0 12px 30px rgba(17, 17, 17, 0.04);
    }
    .island-heading {
      display: grid;
      gap: 0.35rem;
      margin-bottom: 1rem;
    }
    .island-heading h3 {
      margin: 0;
      font-family: 'EB Garamond', serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--ink);
    }
    .island-heading p {
      margin: 0;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.92rem;
      line-height: 1.55;
      color: var(--ink-light);
    }
    .island-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .island-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .island-field {
      display: grid;
      gap: 0.35rem;
    }
    .island-field-wide {
      grid-column: 1 / -1;
    }
    .island-field span {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-faint);
    }
    .island-field input {
      width: 100%;
      border: 1px solid #d9dde6;
      background: #fff;
      border-radius: 7px;
      padding: 0.7rem 0.8rem;
      font: inherit;
      color: var(--ink);
    }
    .island-field input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(42, 92, 170, 0.12);
    }
    .island-output-list {
      display: grid;
      gap: 0.8rem;
      margin-top: 1rem;
    }
    .island-output {
      margin-top: 1rem;
    }
    .island-output-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.45rem;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.84rem;
      color: var(--ink-mid);
    }
    .island-copy,
