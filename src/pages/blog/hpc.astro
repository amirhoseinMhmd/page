  <script is:inline>
    const btn = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const icon = btn?.querySelector('i');
    const progress = document.getElementById('reading-progress');

    btn?.addEventListener('click', () => {
      menu?.classList.toggle('open');
      icon?.classList.toggle('fa-bars');
      icon?.classList.toggle('fa-times');
    });

    document.querySelectorAll('.mobile-nav a').forEach((link) => {
      link.addEventListener('click', () => {
        menu?.classList.remove('open');
        icon?.classList.add('fa-bars');
        icon?.classList.remove('fa-times');
      });
    });

    const article = document.querySelector('article');
    const updateProgress = () => {
      if (!article || !progress) {
        return;
      }

      const articleTop = article.offsetTop;
      const articleHeight = article.offsetHeight;
      const viewportHeight = window.innerHeight;
      const denominator = Math.max(articleHeight - viewportHeight * 0.65, 1);
      const numerator = window.scrollY - articleTop + viewportHeight * 0.2;
      const ratio = Math.min(Math.max(numerator / denominator, 0), 1);
      progress.style.transform = `scaleX(${ratio})`;
    };

    updateProgress();
    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', updateProgress);

    const tocLinks = Array.from(document.querySelectorAll('.toc a[href^="#"]'));
    const observedSections = tocLinks
      .map((link) => document.querySelector(link.getAttribute('href')))
      .filter(Boolean);

    if (tocLinks.length && observedSections.length) {
      const activateTocLink = (activeId) => {
        tocLinks.forEach((link) => {
          link.classList.toggle('active', link.getAttribute('href') === `#${activeId}`);
        });
      };

      const tocObserver = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

        if (visible[0]?.target?.id) {
          activateTocLink(visible[0].target.id);
        }
      }, {
        rootMargin: '-18% 0px -65% 0px',
        threshold: [0.15, 0.35, 0.6],
      });

      observedSections.forEach((section) => tocObserver.observe(section));
    }

    const normalizeCodeText = (raw) => {
      const lines = raw.replace(/\u00a0/g, ' ').split('\n');

      while (lines.length && !lines[0].trim()) {
        lines.shift();
      }

      while (lines.length && !lines[lines.length - 1].trim()) {
        lines.pop();
      }

      const indents = lines
        .filter((line) => line.trim())
        .map((line) => (line.match(/^ */) || [''])[0].length);
      const minIndent = indents.length ? Math.min(...indents) : 0;

      return lines.map((line) => line.slice(minIndent)).join('\n');
    };

    document.querySelectorAll('.code-block').forEach((block) => {
      if (block.parentElement?.classList.contains('code-block-wrap')) {
        return;
      }

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrap';

      const toolbar = document.createElement('div');
      toolbar.className = 'code-block-toolbar';

      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'copy-code-button';
      button.textContent = 'Copy';

      toolbar.appendChild(button);
      block.parentNode?.insertBefore(wrapper, block);
      wrapper.appendChild(toolbar);
      wrapper.appendChild(block);

      button.addEventListener('click', async () => {
        const text = normalizeCodeText(block.textContent || '');

        try {
          await navigator.clipboard.writeText(text);
          button.textContent = 'Copied';
          button.classList.add('copied');
          window.setTimeout(() => {
            button.textContent = 'Copy';
            button.classList.remove('copied');
          }, 1800);
        } catch (_error) {
          button.textContent = 'Copy failed';
          window.setTimeout(() => {
            button.textContent = 'Copy';
          }, 1800);
        }
      });
    });
  </script>
